<Window x:Class="SimpleCalculatorMVVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="300" Width="350" MinHeight="300" MinWidth="350" SizeChanged="Window_SizeChanged">

    <Window.Resources>
        <Style x:Key="AuxiliaryDisplayStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="24"/>
        </Style>
        <Style x:Key="DisplayStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="30"/>
        </Style>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    
    <DockPanel>
        <!-- Меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Калькулятор">
                <MenuItem Header="Версия для слабовидящих" IsCheckable="True" />
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Помощь" Click="Help_Click"/>
            <MenuItem Header="О программе" Click="AboutProgram_Click"/>
        </Menu>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Дисплеи -->
            <StackPanel Margin="0,0,0,10" HorizontalAlignment="Stretch">
                <TextBox x:Name="AuxiliaryDisplay" IsReadOnly="True" TextAlignment="Right"  Focusable="False" Style="{StaticResource AuxiliaryDisplayStyle}" />
                <TextBox x:Name="Display" IsReadOnly="True" TextAlignment="Right"  Focusable="False" Style="{StaticResource DisplayStyle}"/>
            </StackPanel>

            <!-- Кнопки -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Кнопки для цифр -->
                <Button Content="1" Grid.Row="2" Grid.Column="0" Click="Button_Click" Focusable="False" />
                <Button Content="2" Grid.Row="2" Grid.Column="1" Click="Button_Click" Focusable="False" />
                <Button Content="3" Grid.Row="2" Grid.Column="2" Click="Button_Click" Focusable="False" />
                <Button Content="4" Grid.Row="1" Grid.Column="0" Click="Button_Click" Focusable="False" />
                <Button Content="5" Grid.Row="1" Grid.Column="1" Click="Button_Click" Focusable="False" />
                <Button Content="6" Grid.Row="1" Grid.Column="2" Click="Button_Click" Focusable="False" />
                <Button Content="7" Grid.Row="0" Grid.Column="0" Click="Button_Click" Focusable="False" />
                <Button Content="8" Grid.Row="0" Grid.Column="1" Click="Button_Click" Focusable="False" />
                <Button Content="9" Grid.Row="0" Grid.Column="2" Click="Button_Click" Focusable="False" />
                <Button Content="0" Grid.Row="3" Grid.Column="0" Click="Button_Click" Focusable="False" />

                <!-- Кнопки операций -->
                <Button Content="+" Grid.Row="2" Grid.Column="3" Click="Operation_Click" Background="#FFACD4D3" Focusable="False"/>
                <Button Content="-" Grid.Row="2" Grid.Column="4" Click="Operation_Click" Background="#FFACD4D3" Focusable="False"/>
                <Button Content="*" Grid.Row="1" Grid.Column="3" Click="Operation_Click" Background="#FFACD4D3" Focusable="False"/>
                <Button Content="/" Grid.Row="1" Grid.Column="4" Click="Operation_Click" Background="#FFACD4D3" Focusable="False"/>
                <Button Content="^" Grid.Row="3" Grid.Column="3" Click="Operation_Click" Background="#FFACD4D3" Focusable="False"/>

                <!-- Кнопки специальные -->
                <Button Content="=" Grid.Row="3" Grid.Column="4" Click="Equals_Click" Background="#FFAECB96" Focusable="False"/>
                <Button Content="," Grid.Row="3" Grid.Column="1" Click="Special_Click" Background="#FFACD4D3" Focusable="False"/>
                <Button Content="DEL" Grid.Row="0" Grid.Column="3" Click="Del_Click" Background="#FFED9F9F" Focusable="False"/>
                <Button Content="AC" Grid.Row="0" Grid.Column="4" Click="Clear_Click" Background="#FFED9F9F" Focusable="False"/>
                <Button Content="+/-" Grid.Row="3" Grid.Column="2" Click="Special_Click" Background="#FFACD4D3" Focusable="False"/>
            </Grid>
        </Grid>
    </DockPanel>
</Window>