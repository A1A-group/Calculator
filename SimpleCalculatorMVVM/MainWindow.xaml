<Window x:Class="SimpleCalculatorMVVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="300" Width="350" MinHeight="300" MinWidth="350" Background="{DynamicResource BackgroundColor}" SizeChanged="Window_SizeChanged" Closing="Window_Closing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ResourseDictionaries/Styles.xaml"/>
                <ResourceDictionary Source="/ResourseDictionaries/LightTheme.xaml"/>
                
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>
        <!-- Меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Калькулятор">
                <MenuItem x:Name="DarkThemeMenuItem" Header="Темная тема" IsCheckable="True" Checked="DarkThemeMenuItem_Checked" Unchecked="DarkThemeMenuItem_Unchecked" />
                <MenuItem Header="Выход" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="Помощь" Click="Help_Click" />
            <MenuItem Header="О программе" Click="AboutProgram_Click" />
        </Menu>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Дисплеи -->
            <StackPanel Margin="0,0,0,10" HorizontalAlignment="Stretch">
                <TextBox x:Name="AuxiliaryDisplay" IsReadOnly="True" TextAlignment="Right" Focusable="False" Style="{StaticResource AuxiliaryDisplayStyle}" />
                <TextBox x:Name="Display" IsReadOnly="True" TextAlignment="Right" Focusable="False" Style="{StaticResource DisplayStyle}"/>
            </StackPanel>

            <!-- Кнопки -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Кнопки для цифр -->
                <Button Content="1" Grid.Row="2" Grid.Column="0" Click="Button_Click" Focusable="False" Style="{StaticResource ButtonStyle}" />
                <Button Content="2" Grid.Row="2" Grid.Column="1" Click="Button_Click" Focusable="False" Style="{StaticResource ButtonStyle}" />
                <Button Content="3" Grid.Row="2" Grid.Column="2" Click="Button_Click" Focusable="False" Style="{StaticResource ButtonStyle}" />
                <Button Content="4" Grid.Row="1" Grid.Column="0" Click="Button_Click" Focusable="False" Style="{StaticResource ButtonStyle}" />
                <Button Content="5" Grid.Row="1" Grid.Column="1" Click="Button_Click" Focusable="False" Style="{StaticResource ButtonStyle}" />
                <Button Content="6" Grid.Row="1" Grid.Column="2" Click="Button_Click" Focusable="False" Style="{StaticResource ButtonStyle}" />
                <Button Content="7" Grid.Row="0" Grid.Column="0" Click="Button_Click" Focusable="False" Style="{StaticResource ButtonStyle}" />
                <Button Content="8" Grid.Row="0" Grid.Column="1" Click="Button_Click" Focusable="False" Style="{StaticResource ButtonStyle}" />
                <Button Content="9" Grid.Row="0" Grid.Column="2" Click="Button_Click" Focusable="False" Style="{StaticResource ButtonStyle}" />
                <Button Content="0" Grid.Row="3" Grid.Column="0" Click="Button_Click" Focusable="False" Style="{StaticResource ButtonStyle}" />

                <!-- Кнопки операций -->
                <Button Content="+" Grid.Row="2" Grid.Column="3" Click="Operation_Click" Focusable="False" Style="{StaticResource OperationButtonStyle}" />
                <Button Content="-" Grid.Row="2" Grid.Column="4" Click="Operation_Click" Focusable="False" Style="{StaticResource OperationButtonStyle}" />
                <Button Content="*" Grid.Row="1" Grid.Column="3" Click="Operation_Click" Focusable="False" Style="{StaticResource OperationButtonStyle}" />
                <Button Content="/" Grid.Row="1" Grid.Column="4" Click="Operation_Click" Focusable="False" Style="{StaticResource OperationButtonStyle}" />
                <Button Content="^" Grid.Row="3" Grid.Column="3" Click="Operation_Click" Focusable="False" Style="{StaticResource OperationButtonStyle}" />

                <!-- Кнопки специальные -->
                <Button Content="=" Grid.Row="3" Grid.Column="4" Click="Equals_Click" Focusable="False" Style="{StaticResource EqualsButtonStyle}" />
                <Button Content="," Grid.Row="3" Grid.Column="1" Click="Special_Click" Focusable="False" Style="{StaticResource OperationButtonStyle}" />
                <Button Content="DEL" Grid.Row="0" Grid.Column="3" Click="Del_Click" Focusable="False" Style="{StaticResource DelButtonStyle}" />
                <Button Content="AC" Grid.Row="0" Grid.Column="4" Click="Clear_Click" Focusable="False" Style="{StaticResource DelButtonStyle}" />
                <Button Content="+/-" Grid.Row="3" Grid.Column="2" Click="Special_Click" Focusable="False" Style="{StaticResource OperationButtonStyle}" />
            </Grid>
        </Grid>
    </DockPanel>
</Window>