<Window x:Class="SimpleCalculatorMVVM.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Помощь" Height="200" Width="300" 
        Background="{DynamicResource BackgroundColor}" ResizeMode="NoResize">

    <StackPanel Margin="10">
        <TextBlock Text="Это калькулятор. Используйте кнопки для выполнения операций." 
                   TextWrapping="Wrap" 
                   Foreground="{DynamicResource ForegroundColor}"/>
        <Button Content="Закрыть" Click="CloseButton_Click" Margin="0,10,0,0" 
                Style="{DynamicResource ButtonStyle}"/>
    </StackPanel>
</Window>