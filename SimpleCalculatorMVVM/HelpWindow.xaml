<Window x:Class="SimpleCalculatorMVVM.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Помощь" Height="300" Width="350" 
        Background="{DynamicResource BackgroundColor}" ResizeMode="NoResize">

    <StackPanel Margin="10">
        <TextBlock Text="Это простое приложение-калькулятор, поддерживающее базовые арифметические операции: сложение, вычитание, умножение и деление. Для начала работы введите числа и выберите нужную операцию — результат отобразится автоматически." 
                   TextWrapping="Wrap" 
                   Foreground="{DynamicResource ForegroundColor}"/>

        <Image Source="Images/calculator.png"
               Height="100" 
               Margin="0,10,0,0" 
               Stretch="Uniform"/>

        <Button Content="Закрыть" Click="CloseButton_Click" Margin="0,10,0,0" 
                Style="{DynamicResource ButtonStyle}"/>
    </StackPanel>
</Window>
