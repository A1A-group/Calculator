    <SolidColorBrush x:Key="DelButtonForeground" Color="#000000"/>
    <SolidColorBrush x:Key="EqualsButtonBackground" Color="#FFAECB96"/>
    <SolidColorBrush x:Key="EqualsButtonForeground" Color="#000000"/>
    <SolidColorBrush x:Key="MenuItemBackgroundColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="MenuItemForegroundColor" Color="#000000"/>
</ResourceDictionary>