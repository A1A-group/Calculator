<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Ресурсы для тёмной темы -->
    <SolidColorBrush x:Key="BackgroundColor" Color="#333333"/>
    <SolidColorBrush x:Key="ForegroundColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DisplayBackgroundColor" Color="#444444"/>
    <SolidColorBrush x:Key="DisplayForegroundColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonBackground" Color="#444444"/>
    <SolidColorBrush x:Key="ButtonForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OperationButtonBackground" Color="#444444"/>
    <SolidColorBrush x:Key="OperationButtonForeground" Color="#FFACD4D3"/>
    <SolidColorBrush x:Key="DelButtonBackground" Color="#444444"/>
    <SolidColorBrush x:Key="DelButtonForeground" Color="#FFED9F9F"/>
    <SolidColorBrush x:Key="EqualsButtonBackground" Color="#444444"/>
    <SolidColorBrush x:Key="EqualsButtonForeground" Color="#FFAECB96"/>
    <SolidColorBrush x:Key="MenuItemBackgroundColor" Color="#444444"/>
    <SolidColorBrush x:Key="MenuItemForegroundColor" Color="#FFFFFF"/>
</ResourceDictionary>