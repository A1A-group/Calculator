<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="350" Width="400">
    <Grid>
        <Grid
            Margin="10,10,10,240">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBox x:Name="AuxiliaryDisplay" FontSize="12" IsReadOnly="True" Grid.Row="0" Grid.Column="0" />
            <TextBox x:Name="Display" FontSize="24" IsReadOnly="True" Grid.Row="1" Grid.Column="0" />
        </Grid>
        <Grid
            Margin="10, 110, 10, 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Кнопки для цифр -->
            <Button Content="1" Grid.Row="2" Grid.Column="0"/>
            <Button Content="2" Grid.Row="2" Grid.Column="1"/>
            <Button Content="3" Grid.Row="2" Grid.Column="2"/>
            <Button Content="4" Grid.Row="1" Grid.Column="0"/>
            <Button Content="5" Grid.Row="1" Grid.Column="1"/>
            <Button Content="6" Grid.Row="1" Grid.Column="2"/>
            <Button Content="7" Grid.Row="0" Grid.Column="0"/>
            <Button Content="8" Grid.Row="0" Grid.Column="1"/>
            <Button Content="9" Grid.Row="0" Grid.Column="2"/>
            <Button Content="0" Grid.Row="3" Grid.Column="0"/>

            <!-- Кнопки операций -->
            <Button Content="+" Grid.Row="2" Grid.Column="3" Background="#FFACD4D3"/>
            <Button Content="-" Grid.Row="2" Grid.Column="4" Background="#FFACD4D3"/>
            <Button Content="*" Grid.Row="1" Grid.Column="3" Background="#FFACD4D3"/>
            <Button Content="/" Grid.Row="1" Grid.Column="4" Background="#FFACD4D3"/>
            <Button Content="^" Grid.Row="3" Grid.Column="3" Background="#FFACD4D3"/>
            <Button Content="+/-" Grid.Row="3" Grid.Column="2" Background="#FFACD4D3"/>

            <!-- Кнопки специальные -->
            <Button Content="=" Grid.Row="3" Grid.Column="4" Background="#FFAECB96"/>
            <Button Content="," Grid.Row="3" Grid.Column="1" Background="#FFACD4D3"/>
            <Button Content="DEL" Grid.Row="0" Grid.Column="3" Background="#FFED9F9F"/>
            <Button Content="АC" Grid.Row="0" Grid.Column="4" Background="#FFED9F9F"/>
        </Grid>
    </Grid>
</Window>
